{"ast":null,"code":"```javascript\nimport React, { useState, useEffect } from 'react';\nimport { Link } from 'react-router-dom';\n\nfunction Home() {\n  const [clientData, setClientData] = useState(null);\n\n  useEffect(() => {\n    const loggedInUser = localStorage.getItem('clientUser');\n    if (loggedInUser) {\n      setClientData(JSON.parse(loggedInUser));\n    }\n  }, []);\n\n  const handleLogout = () => {\n    localStorage.removeItem('clientUser');\n    setClientData(null);\n    window.location.reload(); \n  };\n\n  return (\n    <div className=\"home-page\">\n\n      {/* Hero Section */}\n      <header \n        className=\"py-5 text-white\" \n        style={{ \n          background: 'linear-gradient(135deg, #1e3c72 0%, #2a5298 100%)',\n          minHeight: '80vh',\n          display: 'flex',\n          alignItems: 'center'\n        }}\n      >\n        <div className=\"container py-5 text-center text-lg-start\">\n          <div className=\"row align-items-center\">\n\n            {/* Left Content */}\n            <div className=\"col-lg-6 mb-5 mb-lg-0\">\n              <h1 className=\"display-4 fw-bold mb-3\">\n                Build Your Next <span className=\"text-warning\">Big Project</span>\n              </h1>\n              <p className=\"lead fs-4 mb-4 opacity-75\">\n                Professional web development and UI/UX designs.\n              </p>\n              <Link to=\"/services\" className=\"btn btn-warning btn-lg px-5 fw-bold shadow\">\n                Explore Services\n              </Link>\n            </div>\n\n            {/* Carousel */}\n            <div className=\"col-lg-6\">\n              <div \n                id=\"heroCarousel\" \n                className=\"carousel slide shadow-lg rounded-4 overflow-hidden\" \n                data-bs-ride=\"carousel\"\n              >\n                <div className=\"carousel-inner\">\n\n                  <div className=\"carousel-item active\">\n                    <img \n                      src=\"https://images.unsplash.com/photo-1521737604893-d14cc237f11d\"\n                      className=\"d-block w-100\"\n                      style={{ height: '400px', objectFit: 'cover' }}\n                      alt=\"Students Working\"\n                    />\n                  </div>\n\n                  <div className=\"carousel-item\">\n                    <img \n                      src=\"https://images.unsplash.com/photo-1556761175-b413da4baf72\"\n                      className=\"d-block w-100\"\n                      style={{ height: '400px', objectFit: 'cover' }}\n                      alt=\"Freelance Work\"\n                    />\n                  </div>\n\n                  <div className=\"carousel-item\">\n                    <img \n                      src=\"https://images.unsplash.com/photo-1519389950473-47ba0277781c\"\n                      className=\"d-block w-100\"\n                      style={{ height: '400px', objectFit: 'cover' }}\n                      alt=\"Laptop Work\"\n                    />\n                  </div>\n\n                </div>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </header>\n\n      {/* Cards Section */}\n      <section className=\"py-5 bg-light\">\n        <div className=\"container\">\n          <div className=\"row text-center\">\n\n            <div className=\"col-md-4 mb-4\">\n              <div className=\"card shadow h-100 border-0 rounded-4\">\n                <div className=\"card-body\">\n                  <h5 className=\"fw-bold\">Secure Payments</h5>\n                  <p>Your transactions are safe and protected.</p>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"col-md-4 mb-4\">\n              <div className=\"card shadow h-100 border-0 rounded-4\">\n                <div className=\"card-body\">\n                  <h5 className=\"fw-bold\">Verified Freelancers</h5>\n                  <p>Work with trusted student freelancers.</p>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"col-md-4 mb-4\">\n              <div className=\"card shadow h-100 border-0 rounded-4\">\n                <div className=\"card-body\">\n                  <h5 className=\"fw-bold\">Fast Delivery</h5>\n                  <p>Get your work done quickly and efficiently.</p>\n                </div>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </section>\n\n      {/* Map Section */}\n      <section id=\"contact\" className=\"py-5 bg-white\">\n        <div className=\"container py-5\">\n          <h2 className=\"text-center fw-bold mb-5\">Find Us Here</h2>\n          <div className=\"row justify-content-center\">\n            <div className=\"col-lg-10\">\n              <div className=\"shadow rounded-4 overflow-hidden\" style={{ height: '400px' }}>\n                <iframe\n                  title=\"Google Map\"\n                  src=\"https://www.google.com/maps?q=Nashik,Maharashtra&output=embed\"\n                  width=\"100%\"\n                  height=\"100%\"\n                  style={{ border: 0 }}\n                  allowFullScreen=\"\"\n                  loading=\"lazy\"\n                ></iframe>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n    </div>\n  );\n}\n\nexport default Home;\n```;","map":{"version":3,"names":[],"sources":["D:/My_Freelancer_Project/frontend/src/pages/Home.js"],"sourcesContent":["```javascript\r\nimport React, { useState, useEffect } from 'react';\r\nimport { Link } from 'react-router-dom';\r\n\r\nfunction Home() {\r\n  const [clientData, setClientData] = useState(null);\r\n\r\n  useEffect(() => {\r\n    const loggedInUser = localStorage.getItem('clientUser');\r\n    if (loggedInUser) {\r\n      setClientData(JSON.parse(loggedInUser));\r\n    }\r\n  }, []);\r\n\r\n  const handleLogout = () => {\r\n    localStorage.removeItem('clientUser');\r\n    setClientData(null);\r\n    window.location.reload(); \r\n  };\r\n\r\n  return (\r\n    <div className=\"home-page\">\r\n\r\n      {/* Hero Section */}\r\n      <header \r\n        className=\"py-5 text-white\" \r\n        style={{ \r\n          background: 'linear-gradient(135deg, #1e3c72 0%, #2a5298 100%)',\r\n          minHeight: '80vh',\r\n          display: 'flex',\r\n          alignItems: 'center'\r\n        }}\r\n      >\r\n        <div className=\"container py-5 text-center text-lg-start\">\r\n          <div className=\"row align-items-center\">\r\n\r\n            {/* Left Content */}\r\n            <div className=\"col-lg-6 mb-5 mb-lg-0\">\r\n              <h1 className=\"display-4 fw-bold mb-3\">\r\n                Build Your Next <span className=\"text-warning\">Big Project</span>\r\n              </h1>\r\n              <p className=\"lead fs-4 mb-4 opacity-75\">\r\n                Professional web development and UI/UX designs.\r\n              </p>\r\n              <Link to=\"/services\" className=\"btn btn-warning btn-lg px-5 fw-bold shadow\">\r\n                Explore Services\r\n              </Link>\r\n            </div>\r\n\r\n            {/* Carousel */}\r\n            <div className=\"col-lg-6\">\r\n              <div \r\n                id=\"heroCarousel\" \r\n                className=\"carousel slide shadow-lg rounded-4 overflow-hidden\" \r\n                data-bs-ride=\"carousel\"\r\n              >\r\n                <div className=\"carousel-inner\">\r\n\r\n                  <div className=\"carousel-item active\">\r\n                    <img \r\n                      src=\"https://images.unsplash.com/photo-1521737604893-d14cc237f11d\"\r\n                      className=\"d-block w-100\"\r\n                      style={{ height: '400px', objectFit: 'cover' }}\r\n                      alt=\"Students Working\"\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"carousel-item\">\r\n                    <img \r\n                      src=\"https://images.unsplash.com/photo-1556761175-b413da4baf72\"\r\n                      className=\"d-block w-100\"\r\n                      style={{ height: '400px', objectFit: 'cover' }}\r\n                      alt=\"Freelance Work\"\r\n                    />\r\n                  </div>\r\n\r\n                  <div className=\"carousel-item\">\r\n                    <img \r\n                      src=\"https://images.unsplash.com/photo-1519389950473-47ba0277781c\"\r\n                      className=\"d-block w-100\"\r\n                      style={{ height: '400px', objectFit: 'cover' }}\r\n                      alt=\"Laptop Work\"\r\n                    />\r\n                  </div>\r\n\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n          </div>\r\n        </div>\r\n      </header>\r\n\r\n      {/* Cards Section */}\r\n      <section className=\"py-5 bg-light\">\r\n        <div className=\"container\">\r\n          <div className=\"row text-center\">\r\n\r\n            <div className=\"col-md-4 mb-4\">\r\n              <div className=\"card shadow h-100 border-0 rounded-4\">\r\n                <div className=\"card-body\">\r\n                  <h5 className=\"fw-bold\">Secure Payments</h5>\r\n                  <p>Your transactions are safe and protected.</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"col-md-4 mb-4\">\r\n              <div className=\"card shadow h-100 border-0 rounded-4\">\r\n                <div className=\"card-body\">\r\n                  <h5 className=\"fw-bold\">Verified Freelancers</h5>\r\n                  <p>Work with trusted student freelancers.</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div className=\"col-md-4 mb-4\">\r\n              <div className=\"card shadow h-100 border-0 rounded-4\">\r\n                <div className=\"card-body\">\r\n                  <h5 className=\"fw-bold\">Fast Delivery</h5>\r\n                  <p>Get your work done quickly and efficiently.</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n      {/* Map Section */}\r\n      <section id=\"contact\" className=\"py-5 bg-white\">\r\n        <div className=\"container py-5\">\r\n          <h2 className=\"text-center fw-bold mb-5\">Find Us Here</h2>\r\n          <div className=\"row justify-content-center\">\r\n            <div className=\"col-lg-10\">\r\n              <div className=\"shadow rounded-4 overflow-hidden\" style={{ height: '400px' }}>\r\n                <iframe\r\n                  title=\"Google Map\"\r\n                  src=\"https://www.google.com/maps?q=Nashik,Maharashtra&output=embed\"\r\n                  width=\"100%\"\r\n                  height=\"100%\"\r\n                  style={{ border: 0 }}\r\n                  allowFullScreen=\"\"\r\n                  loading=\"lazy\"\r\n                ></iframe>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </section>\r\n\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default Home;\r\n```\r\n"],"mappings":"AAAA,EAAE;AACF;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AAC